-- Biến kiểm soát vòng lặp ngầm cho Auto Tele Gun
_G.AutoPickGunActive = false
local GunDropTeleConnection = nil
local IsCurrentlyTeleporting = false 

-- Hàm Teleport phân đoạn siêu tốc, ép máy chủ nhận diện nhặt súng
local function TeleportToGunPure(gunPart, rootPart)
    if IsCurrentlyTeleporting or not gunPart or not rootPart then return end
    IsCurrentlyTeleporting = true 
    
    pcall(function()
        local RunService = game:GetService("RunService")
        local oldCFrame = rootPart.CFrame
        local targetCFrame = CFrame.new(gunPart.Position)
        
        -- Khóa gia tốc để tránh bị văng do lỗi vật lý
        rootPart.AssemblyLinearVelocity = Vector3.zero
        rootPart.AssemblyAngularVelocity = Vector3.zero
        
        -- Chia nhỏ quãng đường di chuyển thành 3 bước siêu tốc (0.03 giây) để qua mặt Anticheat khoảng cách
        rootPart.CFrame = oldCFrame:Lerp(targetCFrame, 0.4)
        RunService.Heartbeat:Wait()
        
        rootPart.CFrame = oldCFrame:Lerp(targetCFrame, 0.8)
        RunService.Heartbeat:Wait()
        
        rootPart.CFrame = targetCFrame -- Đến chính xác vị trí súng
        
        -- Ép va chạm nhặt đồ bằng lệnh gốc của Roblox kết hợp lệnh Executor
        if firetouchinterest then
            firetouchinterest(rootPart, gunPart, 0)
            RunService.Heartbeat:Wait() -- Giữ chân 1 khung hình để súng kịp vào túi đồ
            firetouchinterest(rootPart, gunPart, 1)
        else
            -- Nếu Executor không hỗ trợ firetouchinterest, bắt buộc phải đợi 2 khung hình để nhặt tự nhiên
            RunService.Heartbeat:Wait()
            RunService.Heartbeat:Wait()
        end
        
        -- Dịch chuyển phân đoạn ngược về vị trí cũ an toàn
        rootPart.CFrame = targetCFrame:Lerp(oldCFrame, 0.5)
        RunService.Heartbeat:Wait()
        
        rootPart.CFrame = oldCFrame
        rootPart.AssemblyLinearVelocity = Vector3.zero
        rootPart.AssemblyAngularVelocity = Vector3.zero
    end)
    
    IsCurrentlyTeleporting = false 
end

