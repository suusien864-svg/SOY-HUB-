                for _, coin in pairs(coinContainer:GetChildren()) do
                    local part = coin:IsA("BasePart") and coin or coin:FindFirstChildWhichIsA("BasePart", true)
                    if part then table.insert(trueCoins, part) end
                end
            end
        end
    end
    return trueCoins
end

-- Vòng lặp chính xử lý di chuyển mượt mà phẳng chống giật
local function StartSmartFarm()
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    
    while _G.SmartCoinFarmActive do
        RunService.Heartbeat:Wait()
        
        local char = LocalPlayer.Character
        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        
        if not rootPart or not humanoid or humanoid.Health <= 0 then
            task.wait(1)
            continue
        end
        
        -- Ép trạng thái vật lý để xuyên vật thể mượt mà, không làm lỗi trọng lực
        humanoid:ChangeState(Enum.HumanoidStateType.Physics)
        
        -- HỆ THỐNG PHẢN XẠ NÉ SIÊU TỐC 40 STUDS
        local murdererRoot = GetMurderer()
        if murdererRoot then
            local distanceToMurderer = (rootPart.Position - murdererRoot.Position).Magnitude
            if distanceToMurderer < SAFE_DISTANCE then
                pcall(function()
                    local runDirection = (rootPart.Position - murdererRoot.Position).Unit
                    local escapeTargetPos = rootPart.Position + (runDirection * 40)
                    local finalEscapePos = Vector3.new(escapeTargetPos.X, rootPart.Position.Y, escapeTargetPos.Z)
                    
                    local escapeDist = (rootPart.Position - finalEscapePos).Magnitude
                    local escapeInfo = TweenInfo.new(escapeDist / ESCAPE_SPEED, Enum.EasingStyle.Linear)
                    local escapeTween = TweenService:Create(rootPart, escapeInfo, {CFrame = CFrame.new(finalEscapePos)})
                    
                    rootPart.AssemblyLinearVelocity = Vector3.zero
                    escapeTween:Play()
                    escapeTween.Completed:Wait()
                end)
                continue
            end
        end
        
        -- DI CHUYỂN ĐẾN XU TRÊN MẶT PHẲNG MƯỢT MÀ (0S COOLDOWN)
        local allCoins = GetTrueMM2Coins()
        if #allCoins > 0 then
            local closestCoin = nil
            local shortestDistance = math.huge
            
            for _, coin in pairs(allCoins) do
                local dist = (rootPart.Position - coin.Position).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    closestCoin = coin
                end
            end
            
            if closestCoin and closestCoin.Parent then
                pcall(function()
                    local targetPos = closestCoin.Position
                    local flatTargetPos = Vector3.new(targetPos.X, rootPart.Position.Y, targetPos.Z)
                    local distanceToCoin = (rootPart.Position - flatTargetPos).Magnitude
                    
                    local tweenInfo = TweenInfo.new(distanceToCoin / WALK_SPEED, Enum.EasingStyle.Linear)
                    local coinTween = TweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(flatTargetPos)})
                    
                    rootPart.AssemblyLinearVelocity = Vector3.zero
                    coinTween:Play()
                    
                    -- Vòng lặp theo dõi khung hình siêu tốc
                    while coinTween.PlaybackState == Enum.PlaybackState.Playing do
                        if not closestCoin or not closestCoin.Parent then
                            coinTween:Cancel()
                            break
                        end
                        
                        local currentDist = (rootPart.Position - closestCoin.Position).Magnitude
                        
                        -- XÓA COOLDOWN: Kích hoạt nhặt xu sớm khi lọt vào bán kính Aura (8 studs)
                        if firetouchinterest and currentDist <= TOUCH_AURA_RANGE then
                            firetouchinterest(rootPart, closestCoin, 0)
                            firetouchinterest(rootPart, closestCoin, 1)
                        end
                        
                        local instantMud = GetMurderer()
                        if instantMud and (rootPart.Position - instantMud.Position).Magnitude < SAFE_DISTANCE then
                            coinTween:Cancel()
                            break
                        end
                        
                        RunService.Heartbeat:Wait()
                    end
                end)
            end
        end
    end
end

