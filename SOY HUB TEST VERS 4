local IsGunNotificationCooling = false

local function WatchGunDrop(obj)
    if not obj then return end
    
    -- Kiểm tra chính xác tên vật thể súng rơi là "GunDrop"
    if obj.Name == "GunDrop" then
        task.defer(function()
            -- Nếu đang trong thời gian khóa, bỏ qua không hiện thông báo tiếp
            if IsGunNotificationCooling then return end
            
            -- Kích hoạt khóa lập tức
            IsGunNotificationCooling = true
            
            -- Hiện duy nhất 1 dòng thông báo tiếng Anh lên góc màn hình
            StarterGui:SetCore("SendNotification", {
                Title = "SOY HUB",
                Text = "The GUN has been DROPPED!",
                Duration = 4 -- Hiển thị trong 4 giây
            })
            
            -- Chờ 3 giây (khi súng đã rớt xong hoàn toàn) rồi mới mở khóa cho lượt súng rơi kế tiếp
            task.wait(3)
            IsGunNotificationCooling = false
        end)
    end
end

