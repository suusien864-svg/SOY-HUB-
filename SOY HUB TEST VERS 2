    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do
            t.Panel.Visible = false
            t.Button.BackgroundColor3 = Color3.fromRGB(195, 224, 250)
            t.Button.TextColor3 = Color3.fromRGB(90, 130, 170)
        end
        panel.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(150, 205, 255)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    Tabs[name] = {Button = btn, Panel = panel}
