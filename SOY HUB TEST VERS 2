-- --- 📌 HÀM HỖ TRỢ ESP PHÂN MÀU NGƯỜI CHƠI ---
_G.EspActive = false
local EspConnections = {}

local function GetRoleColor(player)
    if not player then return Color3.fromRGB(140, 230, 140) end
    if player:FindFirstChild("Backpack") and player.Backpack:FindFirstChild("Knife") or (player.Character and player.Character:FindFirstChild("Knife")) then
        return Color3.fromRGB(255, 120, 120)
    elseif player:FindFirstChild("Backpack") and player.Backpack:FindFirstChild("Gun") or (player.Character and player.Character:FindFirstChild("Gun")) then
        return Color3.fromRGB(130, 180, 255)
    end
    return Color3.fromRGB(140, 230, 140)
end

local function GiamESP(player, character)
    if not character or player == LocalPlayer then return end
    local oldEsp = character:FindFirstChild("SOY_AnimeESP")
    if oldEsp then oldEsp:Destroy() end
    
    local hl = Instance.new("Highlight")
    hl.Name = "SOY_AnimeESP"
    hl.FillColor = GetRoleColor(player)
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency = 0.4
    hl.OutlineTransparency = 0.1
    hl.Adornee = character
    hl.Parent = character
end

local function GoESP(character)
    if character then
        local oldEsp = character:FindFirstChild("SOY_AnimeESP")
        if oldEsp then oldEsp:Destroy() end
    end
end

local function TheoDoiPlayer(p)
    if p == LocalPlayer then return end
    if p.Character then GiamESP(p, p.Character) end
    
        local charCon = p.CharacterAdded:Connect(function(char)
        if _G.EspActive then
            task.wait(0.3)
            GiamESP(p, char)
            local toolCon = char.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and (child.Name == "Knife" or child.Name == "Gun") then
                    GiamESP(p, char)
                end
            end)
            table.insert(EspConnections, toolCon)
        end
    end)

    table.insert(EspConnections, charCon)

    if p:FindFirstChild("Backpack") then
        local bpCon = p.Backpack.ChildAdded:Connect(function()
            if _G.EspActive and p.Character then
                task.defer(GiamESP, p, p.Character)
            end
        end)
        table.insert(EspConnections, bpCon)
    end
end

-- --- 📌 HÀM HỖ TRỢ ESP SÚNG (ĐA NĂNG ĐÃ VÁ LỖI) ---
_G.SoyEspGunActive = false
local SoyGunConnections = {}

local function KiemTraSungRoi(obj)
    if not obj then return false end
    local nameLower = string.lower(obj.Name)
    if obj:IsA("Tool") or obj:IsA("Model") or obj:IsA("BasePart") then
        if nameLower:match("gun") or nameLower:match("pistol") or nameLower:match("revolver") or nameLower:match("drop") then
            if not obj:IsDescendantOf(LocalPlayer.Character) and not obj:IsDescendantOf(LocalPlayer:WaitForChild("Backpack")) then
                local isInPlayer = false
                for _, p in pairs(Players:GetPlayers()) do
                    if (p.Character and obj:IsDescendantOf(p.Character)) or (p:FindFirstChild("Backpack") and obj:IsDescendantOf(p.Backpack)) then
                        isInPlayer = true
                        break
                    end
                end
                if not isInPlayer then return true end
            end
        end
    end
    return false
end

local function TaoKhungSungESP(gunObj)
    if not gunObj or gunObj:FindFirstChild("SOY_GunHighlight") then return end
    local hl = Instance.new("Highlight")
    hl.Name = "SOY_GunHighlight"
    hl.FillColor = Color3.fromRGB(255, 255, 120)
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency = 0.3
    hl.OutlineTransparency = 0.1
    hl.Adornee = gunObj
    hl.Parent = gunObj
    
    local mainPart = gunObj:IsA("BasePart") and gunObj or gunObj:FindFirstChildWhichIsA("BasePart") or gunObj:FindFirstChild("Handle")
    if mainPart then
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "SOY_GunLabel"
        billboard.Size = UDim2.new(0, 120, 0, 30)
        billboard.AlwaysOnTop = true
        billboard.StudsOffset = Vector3.new(0, 2, 0)
        billboard.Adornee = mainPart
        billboard.Parent = gunObj
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = "🔫 " .. string.upper(gunObj.Name)
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextStrokeColor3 = Color3.fromRGB(90, 140, 200)
        label.TextStrokeTransparency = 0
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 13
        label.Parent = billboard
    end
end

local function XoaKhungSungESP(gunObj)
    if gunObj then
        local hl = gunObj:FindFirstChild("SOY_GunHighlight")
        local lbl = gunObj:FindFirstChild("SOY_GunLabel")
        if hl then hl:Destroy() end
        if lbl then lbl:Destroy() end
    end
end

